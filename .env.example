# Firebase Configuration
FIREBASE_PROJECT_ID=vengase-ecommerce
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_STORAGE_BUCKET=vengase-ecommerce.firebasestorage.app

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# JWT Configuration (if using custom auth)
JWT_SECRET=your-jwt-secret
JWT_EXPIRE=24h

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Frontend URL (used for redirects after WebXPay payment callback)
FRONTEND_URL=http://localhost:5173

# Resend Email Configuration
RESEND_API_KEY=
FROM_EMAIL=Vengase <orders@vengase.com>
ADMIN_EMAIL=wevengase@gmail.com
# Optional fallback sender for unverified domains
RESEND_FALLBACK_FROM=onboarding@resend.dev

# EmailJS Configuration (customer email channel)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# WebXPay Payment Gateway
# Get these from your WebXPay merchant dashboard at https://webxpay.com
WEBXPAY_SECRET_KEY=your-webxpay-secret-key-uuid-here
# Paste full RSA public key from WebXPay using \n for line breaks:
# WEBXPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIGf...AB\n-----END PUBLIC KEY-----
WEBXPAY_PUBLIC_KEY=
# Optional override for checkout form action URL.
# Use the URL given by your WebXPay dashboard for your account/mode.
WEBXPAY_CHECKOUT_URL=https://webxpay.com/index.php?route=checkout/billingv6

# Payzy Payment Gateway
PAYZY_SECRET_KEY=your-payzy-secret-key
PAYZY_SHOP_ID=your-payzy-shop-id
PAYZY_TEST_MODE=on
PAYZY_API_BASE_URL=https://api.payzypay.xyz


